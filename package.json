{
  "name": "tukifac-tenant-panel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "version:sync": "node scripts/sync-app-version.mjs",
    "dev": "npm run version:sync && vite",
    "build": "npm run version:sync && tsc && vite build",
    "build:web": "npm run version:sync && tsc && vite build",
    "build:android": "npm run version:sync && tsc && vite build --mode capacitor",
    "preview": "vite preview",
    "lint": "eslint .",
    "tauri": "tauri",
    "tauri:dev": "npm run version:sync && tauri dev",
    "tauri:build": "npm run version:sync && tauri build",
    "cap:sync": "npm run build:android && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npm run cap:sync && npx cap run android",
    "icons:generate": "node scripts/generate-app-icons.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.0.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/keyboard": "^7.0.2",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/screen-orientation": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2",
    "@hookform/resolvers": "^3.9.1",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-opener": "~2.5.4",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "hucre": "^0.5.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.460.0",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.3",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "overrides": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/cli": "2.11.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.2",
    "@tauri-apps/cli": "2.11.2",
    "@types/http-proxy": "^1.17.17",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "http-proxy": "^1.18.1",
    "postcss": "^8.4.47",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^7.2.6"
  }
}
