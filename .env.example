# =============================================================================
# Frontend Tenant — Panel ERP por empresa
#   .env.development  → npm run dev
#   .env.production   → npm run build (deploy en *.tukifac.com)
# =============================================================================

# ── DESARROLLO LOCAL ───────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_TENANT_SLUG=demo
VITE_ROOT_DOMAIN=localhost

# ── PRODUCCIÓN (tukifac.com) — copiar a .env.production ─────────────
#
# Same-origin: la API va al mismo host que la SPA (nginx proxy /api → Go).
# NO definir VITE_API_URL (si existe, se ignora en subdominios tenant).
#
# VITE_ROOT_DOMAIN=tukifac.com
#
# URLs resultantes:
#   https://demo.tukifac.com      → API https://demo.tukifac.com/api/*
#   https://tenant1.tukifac.com   → API https://tenant1.tukifac.com/api/*
#
# INCORRECTO (403 missing_resolved_tenant):
# VITE_API_URL=https://api.tukifac.com
