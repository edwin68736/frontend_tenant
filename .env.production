# Producción — same-origin tenant API (no definir VITE_API_URL).
# El slug sale del subdominio: demo.tukifac.com → demo
# Requisito nginx: proxy /api en *.tukifac.com → backend Go (Host preservado).
# Imágenes /uploads: el frontend usa https://api.tukifac.com por defecto (ver getPublicAssetsBaseUrl).
# Opcional mismo origen: proxy también /uploads y /storage, o VITE_ASSETS_ORIGIN=https://demo.tukifac.com

VITE_ROOT_DOMAIN=tukifac.com
